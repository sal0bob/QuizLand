<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="@color/mainColor"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".QuizActivity">

    <LinearLayout
        android:id="@+id/quiz_head"
        android:background="#39394D"
        android:alpha="0.75"
        android:layout_marginTop="30dp"
        app:layout_constraintTop_toTopOf="parent"
        android:gravity="center_vertical"
        android:layout_height="40dp"
        android:layout_width="match_parent">

        <ImageView
            android:id="@+id/closeImage"
            android:clickable="true"
            android:layout_marginStart="20dp"
            android:src="@drawable/close"
            android:layout_width="15dp"
            android:layout_height="wrap_content"/>

        <TextView
            android:id="@+id/close"
            android:enabled="true"
            android:clickable="true"
            android:textColor="#94A3B8"
            android:text="Выйти"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:layout_weight="1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <ImageView

            android:src="@drawable/timer"
            android:layout_width="15dp"
            android:layout_height="wrap_content"/>

        <TextView
            android:layout_marginEnd="20dp"
            android:textColor="#F59E0B"
            android:id="@+id/time_view"
            android:text="00:11"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

    </LinearLayout>
    
    <androidx.constraintlayout.widget.ConstraintLayout
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/quiz_head"
        android:layout_width="320dp"
        android:layout_height="400dp">

        <LinearLayout
            android:id="@+id/question_inf"
            android:gravity="center_vertical"
            android:layout_width="match_parent"
            android:layout_height="20dp">

            <TextView
                android:textSize="13dp"
                android:textColor="#94A3B8"
                android:text="Вопрос"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:layout_weight="1"
                android:layout_marginStart="2dp"
                android:id="@+id/num_question"
                android:textSize="13dp"
                android:textColor="#94A3B8"
                android:text=""
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:textSize="13dp"
                android:textColor="#94A3B8"
                android:text="Категория: "
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"/>

            <TextView
                android:id="@+id/quiz_category"
                android:textSize="13dp"
                android:textColor="#94A3B8"
                android:text=""
                android:layout_height="wrap_content"
                android:layout_width="wrap_content"/>

        </LinearLayout>

        <TextView
            android:id="@+id/question"
            android:gravity="center"
            android:textSize="20dp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_marginTop="20dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/question_inf"
            android:text="Кто был первым императором Древнего Рима?"
            android:layout_width="280dp"
            android:layout_height="wrap_content"/>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@+id/question"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:background="@drawable/quiz_bg"
                android:minHeight="55dp"
                android:gravity="center_vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:background="@drawable/letter_bg"
                    android:textSize="15dp"
                    android:layout_marginStart="10dp"
                    android:gravity="center"
                    android:textColor="#5459BD"
                    android:text="A"
                    android:layout_width="20dp"
                    android:layout_height="20dp"/>

                <TextView
                    android:textColor="@color/white"
                    android:text="Юлий Цезарь"
                    android:layout_marginStart="10dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>